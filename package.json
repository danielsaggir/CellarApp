{
  "name": "cellarapp",
  "version": "1.0.0",
  "private": true,
  "description": "Fullstack Wine Cellar App (React Native client + Express/Prisma server + Postgres in Docker)",
  "main": "index.js",
  "scripts": {
    "db": "docker-compose up -d",
    "db:down": "docker-compose down",
    "server": "cd server && npx ts-node-dev src/index.ts",
    "client:start": "cd client && npx react-native start",
    "client:ios": "cd client && npx react-native run-ios --simulator='iPhone 17 Pro Max'",
    "client:android": "cd client && npx react-native run-android",
    "wineapp": "concurrently \"npm run db\" \"npm run server\" \"npm run client:start\" \"npm run client:ios\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielsaggir/CellarApp.git"
  },
  "keywords": [
    "react-native",
    "express",
    "prisma",
    "postgres",
    "docker",
    "wine-cellar"
  ],
  "author": "Daniel Saggir",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/danielsaggir/CellarApp/issues"
  },
  "homepage": "https://github.com/danielsaggir/CellarApp#readme",
  "devDependencies": {
    "@react-native-community/cli": "^20.0.2",
    "concurrently": "^9.2.1"
  }
}
