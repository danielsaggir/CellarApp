generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  isAdmin      Boolean  @default(false)
  wines        Wine[]   @relation("UserWines")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Wine {
  id        String   @id @default(uuid())
  name      String
  type      WineType
  country   String
  region    String?
  producer  String?
  vintage   Int?
  imageUrl  String?    // 🔹 URL/נתיב לתמונה
  createdAt DateTime @default(now())
  users     User[]   @relation("UserWines")
}

enum WineType {
  RED
  WHITE
  ROSE
  SPARKLING
  ORANGE
}
